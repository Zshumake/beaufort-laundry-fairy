---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ========== HEADER ========== -->
  <header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 sm:h-20">
        <a href="#" class="flex items-center gap-2 group">
          <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <div>
            <span class="text-lg font-bold text-heading font-heading">Laundry</span>
            <span class="text-lg font-bold text-primary font-accent relative sparkle"> Fairy</span>
          </div>
        </a>

        <nav class="hidden md:flex items-center gap-8">
          <a href="#how-it-works" class="text-sm font-medium text-body hover:text-primary transition-colors link-underline">How It Works</a>
          <a href="#pricing" class="text-sm font-medium text-body hover:text-primary transition-colors link-underline">Pricing</a>
          <a href="#about" class="text-sm font-medium text-body hover:text-primary transition-colors link-underline">About</a>
          <a href="#faq" class="text-sm font-medium text-body hover:text-primary transition-colors link-underline">FAQ</a>
          <a href="#contact" class="text-sm font-medium text-body hover:text-primary transition-colors link-underline">Contact</a>
          <a href="#book" class="inline-flex items-center px-5 py-2.5 bg-accent hover:bg-accent-hover text-white font-semibold rounded-full transition-all duration-200 hover:scale-[1.02] hover:shadow-lg text-sm">
            Schedule Pickup
          </a>
        </nav>

        <button id="mobile-menu-btn" class="md:hidden p-2 text-heading" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="hidden md:hidden pb-4">
        <div class="flex flex-col gap-3 bg-surface rounded-2xl p-4 shadow-lg border border-border">
          <a href="#how-it-works" class="text-body hover:text-primary py-2 font-medium transition-colors">How It Works</a>
          <a href="#pricing" class="text-body hover:text-primary py-2 font-medium transition-colors">Pricing</a>
          <a href="#about" class="text-body hover:text-primary py-2 font-medium transition-colors">About</a>
          <a href="#faq" class="text-body hover:text-primary py-2 font-medium transition-colors">FAQ</a>
          <a href="#contact" class="text-body hover:text-primary py-2 font-medium transition-colors">Contact</a>
          <a href="#book" class="inline-flex items-center justify-center px-5 py-3 bg-accent hover:bg-accent-hover text-white font-semibold rounded-full transition-colors text-sm">
            Schedule Pickup
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== HERO ========== -->
  <section class="min-h-screen flex items-center pt-20 pb-16 bg-gradient-to-br from-surface via-surface to-secondary/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <p class="text-primary font-semibold text-sm tracking-widest uppercase mb-4">Free Pickup & Delivery in Beaufort, SC</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-heading leading-tight mb-6">
            Fresh Laundry,<br />
            <span class="text-primary">Delivered to Your Door</span>
          </h1>
          <p class="text-lg text-body leading-relaxed mb-8 max-w-xl">
            We pick up your dirty laundry, wash, dry, and fold it with care — then bring it right back to your porch. Serving Beaufort zip codes 29901–29907 including MCAS Beaufort base housing.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="#book" class="cta-pulse inline-flex items-center justify-center px-8 py-4 bg-accent hover:bg-accent-hover text-white font-bold rounded-full transition-all duration-200 hover:scale-[1.03] hover:shadow-xl text-lg gap-2 shadow-lg shadow-accent/25">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Schedule a Pickup
            </a>
            <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-4 border-2 border-primary/20 text-primary font-semibold rounded-full hover:border-primary hover:bg-primary/5 transition-all duration-300 text-lg gap-2 group">
              See How It Works
              <svg class="w-5 h-5 group-hover:translate-y-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </a>
          </div>
          <div class="flex flex-wrap gap-6 text-sm text-muted">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <span>5-Star Reviews</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
              <span>Military Family Owned</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span>Free Pickup & Delivery</span>
            </div>
          </div>
        </div>
        <div class="reveal reveal-delay-2 relative">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl aspect-[4/3] bg-secondary">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent"></div>
            <img src="https://images.unsplash.com/photo-1582735689369-4fe89db7114c?w=800&q=80" alt="Fresh folded laundry in a bright, clean setting" class="w-full h-full object-cover" loading="eager" />
          </div>
          <div class="absolute -bottom-4 -left-4 bg-surface rounded-2xl shadow-xl p-4 border border-border">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-success/10 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="font-bold text-heading text-sm">24-Hour Turnaround</p>
                <p class="text-muted text-xs">Fresh & folded, fast</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section id="how-it-works" class="py-20 sm:py-28 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-primary font-semibold text-sm tracking-widest uppercase mb-3">Simple & Easy</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-heading">How It Works</h2>
        <p class="text-body mt-4 max-w-2xl mx-auto text-lg">No upfront payment needed. Just schedule a pickup and we handle the rest — you only pay after we've weighed your laundry.</p>
      </div>
      <div class="grid md:grid-cols-4 gap-6 lg:gap-8 relative">
        <div class="hidden md:block absolute top-16 left-[15%] right-[15%] h-0.5 border-t-2 border-dashed border-primary/20"></div>
        <div class="reveal reveal-delay-1 text-center relative">
          <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg relative z-10">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <div class="bg-surface rounded-2xl p-6 shadow-sm border border-border hover:shadow-md hover:-translate-y-1 transition-all duration-300">
            <span class="text-accent font-accent text-2xl font-bold">Step 1</span>
            <h3 class="text-xl font-heading font-bold text-heading mt-2 mb-3">Schedule a Pickup</h3>
            <p class="text-body">Book online — no payment needed upfront. Leave your laundry bag on the porch and we'll grab it.</p>
          </div>
        </div>
        <div class="reveal reveal-delay-2 text-center relative">
          <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg relative z-10">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z"/></svg>
          </div>
          <div class="bg-surface rounded-2xl p-6 shadow-sm border border-border hover:shadow-md hover:-translate-y-1 transition-all duration-300">
            <span class="text-accent font-accent text-2xl font-bold">Step 2</span>
            <h3 class="text-xl font-heading font-bold text-heading mt-2 mb-3">We Weigh & Invoice</h3>
            <p class="text-body">We weigh your laundry and send you an invoice by email at $1.75/lb. You pay online before we wash.</p>
          </div>
        </div>
        <div class="reveal reveal-delay-3 text-center relative">
          <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg relative z-10">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
          </div>
          <div class="bg-surface rounded-2xl p-6 shadow-sm border border-border hover:shadow-md hover:-translate-y-1 transition-all duration-300">
            <span class="text-accent font-accent text-2xl font-bold">Step 3</span>
            <h3 class="text-xl font-heading font-bold text-heading mt-2 mb-3">We Wash & Fold</h3>
            <p class="text-body">Once paid, we wash, dry, and fold everything with care using quality detergents.</p>
          </div>
        </div>
        <div class="reveal reveal-delay-4 text-center relative">
          <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg relative z-10">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
          </div>
          <div class="bg-surface rounded-2xl p-6 shadow-sm border border-border hover:shadow-md hover:-translate-y-1 transition-all duration-300">
            <span class="text-accent font-accent text-2xl font-bold">Step 4</span>
            <h3 class="text-xl font-heading font-bold text-heading mt-2 mb-3">We Deliver It Back</h3>
            <p class="text-body">Fresh, clean, and perfectly folded laundry returned right to your porch. It's like magic!</p>
          </div>
        </div>
      </div>
      <div class="text-center mt-12 reveal">
        <a href="#book" class="inline-flex items-center px-8 py-4 bg-accent hover:bg-accent-hover text-white font-bold rounded-full transition-all duration-200 hover:scale-[1.02] hover:shadow-xl text-lg gap-2">
          Schedule Your First Pickup
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section id="pricing" class="py-20 sm:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-primary font-semibold text-sm tracking-widest uppercase mb-3">Transparent Pricing</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-heading">Simple, Honest Pricing</h2>
        <p class="text-body mt-4 max-w-2xl mx-auto text-lg">No hidden fees. We weigh your laundry after pickup and send you an invoice before we start washing.</p>
      </div>
      <div class="max-w-lg mx-auto reveal">
        <div class="bg-surface rounded-3xl shadow-xl border border-border overflow-hidden">
          <div class="bg-gradient-to-r from-primary to-primary-light p-8 text-center text-white">
            <h3 class="text-xl font-heading font-bold mb-2">Wash, Dry & Fold</h3>
            <div class="flex items-baseline justify-center gap-1">
              <span class="text-6xl font-heading font-bold">$1.75</span>
              <span class="text-xl opacity-80">/ lb</span>
            </div>
            <p class="mt-2 opacity-80">15 lb minimum per order</p>
          </div>
          <div class="p-8">
            <ul class="space-y-4">
              {['Free porch pickup', 'Free delivery', 'Weighed after pickup — no surprises', '24-hour turnaround', 'Quality detergents (free & clear available)', 'Kids & baby clothes welcome'].map((item) => (
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-success shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="mt-8 p-6 bg-surface-alt rounded-2xl border border-border">
              <h4 class="text-sm font-semibold text-heading uppercase tracking-wide mb-4">Estimate Your Cost</h4>
              <div class="space-y-4">
                <div>
                  <div class="flex justify-between text-sm mb-2">
                    <span class="text-body">Pounds of laundry</span>
                    <span id="weight-display" class="font-bold text-heading">20 lbs</span>
                  </div>
                  <input type="range" id="weight-slider" min="15" max="60" value="20" step="1" class="w-full h-2 bg-border rounded-full appearance-none cursor-pointer accent-primary" />
                  <div class="flex justify-between text-xs text-muted mt-1">
                    <span>15 lbs</span>
                    <span>60 lbs</span>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-4 border-t border-border">
                  <span class="text-body font-medium">Estimated Total</span>
                  <span id="price-display" class="text-3xl font-heading font-bold text-primary">$35.00</span>
                </div>
              </div>
            </div>
            <a href="#book" class="mt-8 w-full inline-flex items-center justify-center px-8 py-4 bg-accent hover:bg-accent-hover text-white font-bold rounded-full transition-all duration-200 hover:scale-[1.02] hover:shadow-lg text-lg">
              Schedule a Pickup
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ABOUT ========== -->
  <section id="about" class="py-20 sm:py-28 bg-secondary/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="reveal order-2 lg:order-1">
          <div class="relative">
            <div class="rounded-3xl overflow-hidden shadow-2xl aspect-[3/4] bg-secondary ring-1 ring-border">
              <img src="/images/courtney.webp" alt="Courtney, owner of Beaufort Laundry Fairy, holding a laundry basket" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <!-- Decorative accent -->
            <div class="absolute -z-10 -bottom-4 -right-4 w-full h-full rounded-3xl bg-primary/10"></div>
          </div>
        </div>
        <div class="reveal order-1 lg:order-2">
          <p class="text-primary font-semibold text-sm tracking-widest uppercase mb-3">Meet Your Laundry Fairy</p>
          <h2 class="text-3xl sm:text-4xl font-heading font-bold text-heading mb-6">A Local Mom-Run Business You Can Trust</h2>
          <div class="space-y-4 text-body text-lg leading-relaxed">
            <p>Hi, I'm Courtney! I'm a stay-at-home mom in the Shadow Moss neighborhood of Beaufort. I started this laundry service to support my family while being home with my two daughters.</p>
            <p>I genuinely enjoy doing laundry — there's something satisfying about fresh, clean clothes and everything folded just right! My husband is stationed at MCAS Beaufort, so I have base access and love serving our military families.</p>
            <p>I'm all about quick, clear communication and treating your clothes like my own. Thanks for supporting a local, mom-run business!</p>
          </div>
          <div class="mt-8 grid grid-cols-2 gap-4">
            {[
              { icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', label: 'Military Spouse Owned' },
              { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z', label: 'Beaufort Local' },
              { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'Base Access' },
              { icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', label: 'Family Friendly' }
            ].map(({ icon, label }) => (
              <div class="flex items-center gap-3 bg-surface rounded-xl p-4 shadow-sm border border-border">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
                </div>
                <span class="text-sm font-medium text-heading">{label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="py-20 sm:py-28 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-primary font-semibold text-sm tracking-widest uppercase mb-3">What People Say</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-heading">Loved by Beaufort Families</h2>
      </div>
      <div class="flex flex-wrap justify-center gap-8 sm:gap-16 mb-16 reveal">
        {[{ val: '50+', label: 'Families Served' }, { val: '5.0', label: 'Average Rating' }, { val: '24hr', label: 'Turnaround' }].map(({ val, label }) => (
          <div class="text-center">
            <p class="text-4xl font-heading font-bold text-primary">{val}</p>
            <p class="text-sm text-muted mt-1">{label}</p>
          </div>
        ))}
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { text: "As a military spouse with three kids, this service has been a lifesaver. Clothes come back perfectly folded every single time. Courtney is amazing!", name: "Sarah M.", role: "Marine spouse, base housing" },
          { text: "So convenient! I just leave my bag on the porch and it comes back clean and folded the next day. The pricing is fair and the communication is great.", name: "Jennifer T.", role: "Shadow Moss resident" },
          { text: "I work long hours and laundry was always piling up. Now I have one less thing to worry about. Best decision I've made! Highly recommend to anyone in Beaufort.", name: "David R.", role: "Beaufort, SC" }
        ].map(({ text, name, role }, i) => (
          <div class={`reveal reveal-delay-${i + 1} relative bg-surface-alt rounded-2xl p-8 border-l-4 border-primary hover:shadow-xl hover:-translate-y-1 transition-all duration-300`}>
            <div class="quote-mark absolute top-4 left-0"></div>
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
