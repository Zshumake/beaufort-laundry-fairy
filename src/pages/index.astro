  <!-- Mobile Sticky CTA -->
  <div id="mobile-cta" class="fixed bottom-0 left-0 right-0 bg-surface/95 backdrop-blur-md border-t border-border px-4 py-2.5 md:hidden translate-y-full transition-transform duration-300 z-40">
    <a href="#book" class="w-full inline-flex items-center justify-center px-6 py-3 bg-accent hover:bg-accent-hover text-white font-bold rounded-full transition-colors text-sm gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Schedule a Pickup
    </a>
  </div>

  <script>
    // Pricing Toggle
    const tabPickup = document.getElementById('tab-pickup')!;
    const tabDropoff = document.getElementById('tab-dropoff')!;
    const priceAmounts = document.querySelectorAll('.price-amount');
    const pickupFeatures = document.querySelectorAll('.pickup-feature');
    let isPickup = true;

    function updatePricing(pickup: boolean) {
      isPickup = pickup;
      priceAmounts.forEach(el => {
        const price = pickup ? el.getAttribute('data-pickup') : el.getAttribute('data-dropoff');
        el.textContent = `$${parseFloat(price!).toFixed(2)}`;
      });
      pickupFeatures.forEach(el => {
        el.textContent = pickup ? 'Free pickup & delivery' : 'You drop off & pick up';
      });
      if (pickup) {
        tabPickup.classList.add('bg-primary', 'text-white', 'shadow-sm');
        tabPickup.classList.remove('text-body');
        tabDropoff.classList.remove('bg-primary', 'text-white', 'shadow-sm');
        tabDropoff.classList.add('text-body');
      } else {
        tabDropoff.classList.add('bg-primary', 'text-white', 'shadow-sm');
        tabDropoff.classList.remove('text-body');
        tabPickup.classList.remove('bg-primary', 'text-white', 'shadow-sm');
        tabPickup.classList.add('text-body');
      }
      updateCalc();
    }
    tabPickup.addEventListener('click', () => updatePricing(true));
    tabDropoff.addEventListener('click', () => updatePricing(false));

    // Price Calculator
    const slider = document.getElementById('weight-slider') as HTMLInputElement;
    const weightDisplay = document.getElementById('weight-display');
    const priceDisplay = document.getElementById('price-display');
    const calcRateLabel = document.getElementById('calc-rate-label');
    const speedBtns = document.querySelectorAll('.calc-speed-btn');
    const typeBtns = document.querySelectorAll('.calc-type-btn');
    let calcType = 'pickup';
    let calcSpeed = document.querySelector('.calc-speed-btn.border-primary') as HTMLElement;

    function styleBtn(btn: Element, active: boolean, group: NodeListOf<Element>) {
      if (active) {
        btn.classList.add('border-primary', 'bg-primary/5', 'text-primary');
        btn.classList.remove('border-border', 'text-body');
        btn.querySelectorAll('.text-heading').forEach(el => el.classList.remove('text-heading'));
        btn.querySelectorAll('.text-muted').forEach(el => el.classList.remove('text-muted'));
      } else {
        btn.classList.remove('border-primary', 'bg-primary/5', 'text-primary');
        btn.classList.add('border-border', 'text-body');
        const bold = btn.querySelector('.font-bold');
        if (bold && !bold.classList.contains('text-heading')) bold.classList.add('text-heading');
        const sub = btn.querySelector('.text-xs');
        if (sub && !sub.classList.contains('text-muted')) sub.classList.add('text-muted');
      }
    }

    function updateCalc() {
      const w = parseInt(slider.value);
      const rate = parseFloat(calcType === 'pickup' ? calcSpeed.dataset.pickup! : calcSpeed.dataset.dropoff!);
      weightDisplay!.textContent = `${w} lbs`;
      priceDisplay!.textContent = `$${(w * rate).toFixed(2)}`;
      const speedLabel = calcSpeed.querySelector('.font-bold')!.textContent!.toLowerCase();
      calcRateLabel!.textContent = `${speedLabel} ${calcType === 'pickup' ? 'pickup & delivery' : 'drop-off'}`;
      // Update speed price labels based on type
      speedBtns.forEach(btn => {
        const priceEl = btn.querySelector('.calc-speed-price');
        if (priceEl) {
          const p = calcType === 'pickup' ? (btn as HTMLElement).dataset.pickup : (btn as HTMLElement).dataset.dropoff;
          priceEl.textContent = `$${parseFloat(p!).toFixed(2)}/lb`;
        }
      });
    }

    speedBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        speedBtns.forEach(b => styleBtn(b, b === btn, speedBtns));
        calcSpeed = btn as HTMLElement;
        updateCalc();
      });
    });

    typeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        typeBtns.forEach(b => styleBtn(b, b === btn, typeBtns));
        calcType = (btn as HTMLElement).dataset.type!;
        updateCalc();
      });
    });

    slider?.addEventListener('input', updateCalc);

    // FAQ Accordion (HTML is server-rendered for SEO)
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const ans = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('svg')!;
        const open = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.faq-btn').forEach(o => { if (o !== btn) { o.setAttribute('aria-expanded','false'); (o.nextElementSibling as HTMLElement).style.maxHeight='0'; o.querySelector('svg')!.classList.remove('rotate-180'); }});
        btn.setAttribute('aria-expanded', String(!open));
        if (!open) { ans.style.maxHeight = ans.scrollHeight + 'px'; icon.classList.add('rotate-180'); }
        else { ans.style.maxHeight = '0'; icon.classList.remove('rotate-180'); }
      });
    });

    // Contact form submit
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = document.getElementById('contact-submit') as HTMLButtonElement;
      btn.textContent = 'Sending...';
      btn.disabled = true;
      try {
        const resp = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'Accept': 'application/json' } });
        if (resp.ok) {
          document.getElementById('contact-fields')?.classList.add('hidden');
          document.getElementById('contact-success')?.classList.remove('hidden');
        } else {
          btn.textContent = 'Try Again';
          btn.disabled = false;
          alert('Something went wrong. Please try again or email us at beaufortlaundryfairy@gmail.com');
        }
      } catch (_) {
        btn.textContent = 'Try Again';
        btn.disabled = false;
        alert('Network error. Please check your connection and try again, or email us at beaufortlaundryfairy@gmail.com');
      }
    });

    // Multi-step form
    const steps = [document.getElementById('step-1'), document.getElementById('step-2'), document.getElementById('step-3')];
    function showStep(n: number) {
      steps.forEach((s, i) => s?.classList.toggle('hidden', i !== n));
      for (let i = 1; i <= 3; i++) {
        const ci = document.querySelector(`#si-${i} div`)!;
        const cl = document.querySelector(`#si-${i} span`);
        if (i <= n + 1) { ci.classList.remove('bg-border','text-muted'); ci.classList.add('bg-primary','text-white'); cl?.classList.remove('text-muted'); cl?.classList.add('text-heading'); }
        else { ci.classList.add('bg-border','text-muted'); ci.classList.remove('bg-primary','text-white'); cl?.classList.add('text-muted'); cl?.classList.remove('text-heading'); }
        const line = document.getElementById(`sl-${i}`);
        if (line) { if (i < n + 1) { line.classList.remove('bg-border'); line.classList.add('bg-primary'); } else { line.classList.add('bg-border'); line.classList.remove('bg-primary'); }}
      }
    }
    document.getElementById('next-1')?.addEventListener('click', () => {
      let valid = true;
      ['name','email','phone','zip','address'].forEach(id => { const el = document.getElementById(id) as HTMLInputElement; if (!el.checkValidity()) { el.reportValidity(); valid = false; }});
      if (valid) showStep(1);
    });
    document.getElementById('next-2')?.addEventListener('click', () => {
      const d = document.getElementById('pickup-date') as HTMLInputElement;
      const t = document.getElementById('pickup-time') as HTMLSelectElement;
      if (!d.value) { d.reportValidity(); return; }
      if (!t.value) { t.reportValidity(); return; }
      const s = document.getElementById('booking-summary')!;
      const esc = (str: string) => { const d2 = document.createElement('div'); d2.textContent = str; return d2.innerHTML; };
      const v = (id: string) => esc((document.getElementById(id) as HTMLInputElement).value);
      const bh = (document.getElementById('base-housing') as HTMLInputElement).checked;
      const ins = esc((document.getElementById('instructions') as HTMLTextAreaElement).value);
      s.innerHTML = [
        ['Name', v('name')], ['Email', v('email')], ['Phone', v('phone')], ['Address', v('address')],
        ...(bh ? [['Base Housing', 'Yes']] : []),
        ['Pickup Date', esc(new Date(d.value + 'T00:00').toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' }))],
        ['Time Window', esc(t.options[t.selectedIndex].text)],
        ...(ins ? [['Notes', ins]] : [])
      ].map(([k,val]) => `<div class="flex justify-between py-2 border-b border-border last:border-0"><span class="text-muted">${k}</span><span class="text-heading font-medium text-right max-w-[60%]">${val}</span></div>`).join('');
      showStep(2);
    });
    document.getElementById('back-2')?.addEventListener('click', () => showStep(0));
    document.getElementById('back-3')?.addEventListener('click', () => showStep(1));
    document.getElementById('booking-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.textContent = 'Submitting...';
      btn.disabled = true;
      try {
        const resp = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'Accept': 'application/json' } });
        if (resp.ok) {
          steps.forEach(s => s?.classList.add('hidden'));
          document.querySelector('#book .bg-surface-alt')?.classList.add('hidden');
          document.getElementById('booking-success')?.classList.remove('hidden');
        } else {
          btn.textContent = 'Try Again';
          btn.disabled = false;
          alert('Something went wrong. Please try again or email us at beaufortlaundryfairy@gmail.com');
        }
      } catch (_) {
        btn.textContent = 'Try Again';
        btn.disabled = false;
        alert('Network error. Please check your connection and try again, or email us at beaufortlaundryfairy@gmail.com');
      }
    });

    // Mobile CTA
    const mobileCta = document.getElementById('mobile-cta');
    const hero = document.querySelector('section');
    new IntersectionObserver(([e]) => {
      mobileCta?.classList.toggle('translate-y-full', e.isIntersecting);
    }, { threshold: 0.1 }).observe(hero!);

    // Min date for pickup
    const pd = document.getElementById('pickup-date') as HTMLInputElement;
    if (pd) { const t = new Date(); t.setDate(t.getDate() + 1); pd.min = t.toISOString().split('T')[0]; }
  </script>
