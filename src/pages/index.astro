  <script>
    // Price Calculator
    const slider = document.getElementById('weight-slider') as HTMLInputElement;
    const weightDisplay = document.getElementById('weight-display');
    const priceDisplay = document.getElementById('price-display');
    slider?.addEventListener('input', () => {
      const w = parseInt(slider.value);
      weightDisplay!.textContent = `${w} lbs`;
      priceDisplay!.textContent = `$${(w * 1.75).toFixed(2)}`;
    });

    // FAQ Accordion
    const faqs = [
      { q: "How does the service work?", a: "Schedule a pickup online (no payment needed). Leave your laundry on the porch and we'll pick it up. We weigh it and send you an invoice by email. Once you pay online, we wash, dry, fold, and deliver it back to your doorstep — usually within 24 hours." },
      { q: "What cleaning products do you use?", a: "We use high-quality, commonly trusted laundry detergents. Free & clear fragrance-free options are available upon request. Just let us know your preferences when booking!" },
      { q: "How should I prepare my laundry?", a: "You can leave your laundry in a trash bag, laundry bag, or your own hamper. We'll return your clean clothes bagged up inside the same container." },
      { q: "How is pricing determined?", a: "After we pick up your laundry, we weigh it and send you an invoice at $1.75 per pound (15 lb minimum). You don't pay anything upfront — you'll get an email with your exact total and a link to pay online before we start washing. A full kitchen trash bag is typically around 15-20 lbs." },
      { q: "What area do you serve?", a: "We serve the Beaufort, SC area including zip codes 29901 through 29907. This includes MCAS Beaufort base housing — we have base access!" },
      { q: "Do you handle baby and children's clothes?", a: "Absolutely! We're happy to wash kids and baby clothes. Just let us know if you'd like us to use Free & Clear detergent or have any other preferences." },
      { q: "What's your cancellation policy?", a: "You can reschedule or cancel anytime via your confirmation email or by contacting us directly. We appreciate at least 12 hours notice when possible." },
      { q: "How do I pay?", a: "No payment is needed when you book. After we pick up and weigh your laundry, we send you an invoice via email with a secure payment link. You can pay with a credit/debit card or bank transfer. We start washing once payment is received." }
    ];
    const fc = document.getElementById('faq-container')!;
    faqs.forEach(faq => {
      const d = document.createElement('div');
      d.className = 'bg-surface rounded-2xl border border-border overflow-hidden';
      d.innerHTML = `<button class="faq-btn w-full flex items-center justify-between p-6 text-left hover:bg-surface-alt/50 transition-colors" aria-expanded="false"><span class="text-heading font-semibold text-base pr-4">${faq.q}</span><svg class="w-5 h-5 text-muted shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></button><div class="faq-ans max-h-0 overflow-hidden transition-all duration-300"><p class="px-6 pb-6 text-body leading-relaxed">${faq.a}</p></div>`;
      fc.appendChild(d);
    });
    document.querySelectorAll('.faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const ans = btn.nextElementSibling as HTMLElement;
        const icon = btn.querySelector('svg')!;
        const open = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.faq-btn').forEach(o => { if (o !== btn) { o.setAttribute('aria-expanded','false'); (o.nextElementSibling as HTMLElement).style.maxHeight='0'; o.querySelector('svg')!.classList.remove('rotate-180'); }});
        btn.setAttribute('aria-expanded', String(!open));
        if (!open) { ans.style.maxHeight = ans.scrollHeight + 'px'; icon.classList.add('rotate-180'); }
        else { ans.style.maxHeight = '0'; icon.classList.remove('rotate-180'); }
      });
    });

    // Multi-step form
    const steps = [document.getElementById('step-1'), document.getElementById('step-2'), document.getElementById('step-3')];
    function showStep(n: number) {
      steps.forEach((s, i) => s?.classList.toggle('hidden', i !== n));
      for (let i = 1; i <= 3; i++) {
        const ci = document.querySelector(`#si-${i} div`)!;
        const cl = document.querySelector(`#si-${i} span`);
        if (i <= n + 1) { ci.classList.remove('bg-border','text-muted'); ci.classList.add('bg-primary','text-white'); cl?.classList.remove('text-muted'); cl?.classList.add('text-heading'); }
        else { ci.classList.add('bg-border','text-muted'); ci.classList.remove('bg-primary','text-white'); cl?.classList.add('text-muted'); cl?.classList.remove('text-heading'); }
        const line = document.getElementById(`sl-${i}`);
        if (line) { if (i < n + 1) { line.classList.remove('bg-border'); line.classList.add('bg-primary'); } else { line.classList.add('bg-border'); line.classList.remove('bg-primary'); }}
      }
    }
    document.getElementById('next-1')?.addEventListener('click', () => {
      let valid = true;
      ['name','email','phone','zip','address'].forEach(id => { const el = document.getElementById(id) as HTMLInputElement; if (!el.checkValidity()) { el.reportValidity(); valid = false; }});
      if (valid) showStep(1);
    });
    document.getElementById('next-2')?.addEventListener('click', () => {
      const d = document.getElementById('pickup-date') as HTMLInputElement;
      const t = document.getElementById('pickup-time') as HTMLSelectElement;
      if (!d.value) { d.reportValidity(); return; }
      if (!t.value) { t.reportValidity(); return; }
      const s = document.getElementById('booking-summary')!;
      const v = (id: string) => (document.getElementById(id) as HTMLInputElement).value;
      const bh = (document.getElementById('base-housing') as HTMLInputElement).checked;
      const ins = (document.getElementById('instructions') as HTMLTextAreaElement).value;
      s.innerHTML = [
        ['Name', v('name')], ['Email', v('email')], ['Phone', v('phone')], ['Address', v('address')],
        ...(bh ? [['Base Housing', 'Yes']] : []),
        ['Pickup Date', new Date(d.value + 'T00:00').toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' })],
        ['Time Window', t.options[t.selectedIndex].text],
        ...(ins ? [['Notes', ins]] : [])
      ].map(([k,val]) => `<div class="flex justify-between py-2 border-b border-border last:border-0"><span class="text-muted">${k}</span><span class="text-heading font-medium text-right max-w-[60%]">${val}</span></div>`).join('');
      showStep(2);
    });
    document.getElementById('back-2')?.addEventListener('click', () => showStep(0));
    document.getElementById('back-3')?.addEventListener('click', () => showStep(1));
    document.getElementById('booking-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      steps.forEach(s => s?.classList.add('hidden'));
      document.querySelector('#book .bg-surface-alt')?.classList.add('hidden');
      document.getElementById('booking-success')?.classList.remove('hidden');
    });

    // Mobile CTA
    const mobileCta = document.getElementById('mobile-cta');
    const hero = document.querySelector('section');
    new IntersectionObserver(([e]) => {
      mobileCta?.classList.toggle('translate-y-full', e.isIntersecting);
    }, { threshold: 0.1 }).observe(hero!);

    // Min date for pickup
    const pd = document.getElementById('pickup-date') as HTMLInputElement;
    if (pd) { const t = new Date(); t.setDate(t.getDate() + 1); pd.min = t.toISOString().split('T')[0]; }
  </script>
</Layout>
