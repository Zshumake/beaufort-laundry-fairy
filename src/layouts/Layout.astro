---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Beaufort Laundry Fairy | Wash, Dry & Fold with Free Pickup & Delivery',
  description = 'Professional wash, dry, and fold laundry service in Beaufort County, SC. Free porch pickup and delivery in Beaufort, Port Royal, Ladies Island, and Bluffton — including MCAS Beaufort base housing.'
} = Astro.props;

const siteUrl = 'https://www.beaufortlaundryfairy.com';
const ogImage = `${siteUrl}/images/courtney.webp`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Beaufort Laundry Fairy" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Additional SEO -->
    <meta name="theme-color" content="#2B7A78" />
    <meta name="robots" content="index, follow" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Inter:wght@300..700&family=Caveat:wght@400..700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Beaufort Laundry Fairy",
      "description": description,
      "url": siteUrl,
      "image": ogImage,
      "email": "beaufortlaundryfairy@gmail.com",
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 32.4316, "longitude": -80.6698 },
        "geoRadius": "15 mi"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Beaufort",
        "addressRegion": "SC",
        "postalCode": "29902",
        "addressCountry": "US"
      },
      "priceRange": "$1.55-$2.85/lb",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "19:00"
      },
      "sameAs": ["https://www.facebook.com/beaufortlaundryfairy"],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Laundry Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Wash, Dry & Fold - 48 Hour Return (Pickup & Delivery)" },
            "price": "1.85",
            "priceCurrency": "USD",
            "unitText": "per pound"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Wash, Dry & Fold - 24 Hour Return (Pickup & Delivery)" },
            "price": "2.25",
            "priceCurrency": "USD",
            "unitText": "per pound"
          },
          {
            "@type": "Offer",
            "itemOffered": { "@type": "Service", "name": "Wash, Dry & Fold - Same Day Return (Pickup & Delivery)" },
            "price": "2.85",
            "priceCurrency": "USD",
            "unitText": "per pound"
          }
        ]
      }
    })} />

    <!-- JSON-LD Structured Data: FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How does the service work?", "acceptedAnswer": { "@type": "Answer", "text": "Schedule a pickup online (no payment needed). Leave your laundry on the porch and we'll pick it up. We weigh it and text you an invoice. Once you pay online, we wash, dry, fold, and deliver it back to your doorstep." }},
        { "@type": "Question", "name": "What cleaning products do you use?", "acceptedAnswer": { "@type": "Answer", "text": "We use high-quality, commonly trusted laundry detergents. Free & clear fragrance-free options are available upon request." }},
        { "@type": "Question", "name": "How is pricing determined?", "acceptedAnswer": { "@type": "Answer", "text": "After we pick up your laundry, we weigh it and send you an invoice. Pricing starts at $1.85/lb for 48-hour return with pickup & delivery, or $1.55/lb if you drop off. 10 lb minimum per order." }},
        { "@type": "Question", "name": "What area do you serve?", "acceptedAnswer": { "@type": "Answer", "text": "We serve Beaufort County, SC including Beaufort, Port Royal, Ladies Island, and Bluffton. Zip codes: 29901-29907, 29909, 29910, and 29935. This includes MCAS Beaufort base housing." }},
        { "@type": "Question", "name": "How do I pay?", "acceptedAnswer": { "@type": "Answer", "text": "No payment is needed when you book. After we pick up and weigh your laundry, we text you an invoice with a secure payment link. You can pay with a credit/debit card or bank transfer." }}
      ]
    })} />
  </head>
  <body class="overflow-x-hidden">
    <slot />
    <script>
      // Scroll reveal observer
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px 200px 0px' });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Mobile menu toggle with animation
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      menuBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('grid-rows-[1fr]');
        mobileMenu?.classList.toggle('grid-rows-[1fr]', !isOpen);
        mobileMenu?.classList.toggle('grid-rows-[0fr]', isOpen);
      });

      // Close mobile menu on link click
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.remove('grid-rows-[1fr]');
          mobileMenu?.classList.add('grid-rows-[0fr]');
        });
      });

      // Sticky header background on scroll
      const header = document.getElementById('header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          header?.classList.add('glass', 'shadow-sm', 'border-b', 'border-border/50');
        } else {
          header?.classList.remove('glass', 'shadow-sm', 'border-b', 'border-border/50');
        }
      });
    </script>
  </body>
</html>
